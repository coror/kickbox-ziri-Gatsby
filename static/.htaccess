# =============================================================================
# Kickbox Žiri – Apache config for neoserv
# Drop into public_html/ alongside the other site files (replaces existing).
# =============================================================================

# -----------------------------------------------------------------------------
# Force HTTPS + non-www (matches the canonical URL set in the build)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # http -> https
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # www -> non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [L,R=301]
</IfModule>

# -----------------------------------------------------------------------------
# Gatsby route handling
#   - Apache's DirectoryIndex automatically serves /programi/ -> /programi/index.html
#   - Unknown routes fall back to Gatsby's built 404 page (not the home page)
# -----------------------------------------------------------------------------
DirectoryIndex index.html
ErrorDocument 404 /404.html

# -----------------------------------------------------------------------------
# Compression (gzip + brotli when available) – the single biggest perceived
# speed win on shared hosting. Cuts JS/CSS/HTML payloads by ~70%.
# -----------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE \
    text/html \
    text/plain \
    text/css \
    text/xml \
    text/javascript \
    application/javascript \
    application/x-javascript \
    application/json \
    application/xml \
    application/rss+xml \
    application/atom+xml \
    image/svg+xml \
    font/woff \
    font/woff2
</IfModule>

<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS \
    text/html \
    text/plain \
    text/css \
    text/xml \
    text/javascript \
    application/javascript \
    application/x-javascript \
    application/json \
    application/xml \
    application/rss+xml \
    application/atom+xml \
    image/svg+xml \
    font/woff \
    font/woff2
</IfModule>

# -----------------------------------------------------------------------------
# Cache headers
#   - Hashed static assets (Gatsby fingerprints these): 1 year, immutable
#   - HTML pages: revalidate on every request (so updates show fast)
#   - sw.js: never cache (so service worker updates are picked up)
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  # Hashed static assets – never change for a given URL, so cache forever
  <FilesMatch "\.(?:js|css|woff2|woff|ttf|eot|jpg|jpeg|png|gif|webp|avif|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML – fresh every request (cheap because of compression + small size)
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Service worker – must always re-check, otherwise updates take forever
  <Files "sw.js">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </Files>

  # Allow cross-origin font loading (mostly defensive)
  <FilesMatch "\.(?:woff|woff2|ttf|eot)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>
